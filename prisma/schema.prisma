generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role     @default(AGENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tickets Ticket[]
}

enum Role {
  ADMIN
  AGENT
}

model Ticket {
  id       String       @id @default(cuid())
  subject  String
  body     String
  from     String
  status   TicketStatus @default(OPEN)
  category Category?

  assignedTo   User?   @relation(fields: [assignedToId], references: [id])
  assignedToId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TicketStatus {
  OPEN
  RESOLVED
  CLOSED
}

enum Category {
  GENERAL_QUESTION
  TECHNICAL_QUESTION
  REFUND_REQUEST
}
