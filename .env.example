# Railway sets PORT automatically — only needed for local dev
PORT=3000
# Set to "production" on Railway (enables the sign-in rate limiter)
NODE_ENV=development
# For production add ?sslmode=require to the connection string
DATABASE_URL=postgresql://user:password@localhost:5432/ticketdb
# Generate with: openssl rand -base64 32  (minimum 32 characters required)
BETTER_AUTH_SECRET=
# Client and server are one Railway service (Express serves the built client) —
# in production BETTER_AUTH_URL and CLIENT_ORIGIN should both be that service's
# public URL, e.g. https://your-app.up.railway.app
BETTER_AUTH_URL=http://localhost:3000
CLIENT_ORIGIN=http://localhost:5173
ADMIN_EMAIL=
# Must be at least 16 characters. Generate with: openssl rand -base64 16
ADMIN_PASSWORD=
# Generate with: openssl rand -base64 32
WEBHOOK_SECRET=
# Gemini API key for the "Polish" reply button — get one at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=
# Sentry DSNs — one project for the server (@sentry/node), one for the client (@sentry/react)
SENTRY_DSN=
VITE_SENTRY_DSN=
