generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  role          Role      @default(AGENT)
  banned        Boolean?
  banReason     String?
  banExpires    DateTime?
  deletedAt     DateTime?
  createdAt     DateTime
  updatedAt     DateTime

  sessions Session[]
  accounts Account[]
  tickets  Ticket[]
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@unique([providerId, accountId])
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?
}

enum Role {
  ADMIN
  AGENT
}

model Ticket {
  id       String       @id @default(cuid())
  subject  String
  body     String
  from     String
  status   TicketStatus @default(OPEN)
  category Category?

  assignedTo   User?   @relation(fields: [assignedToId], references: [id])
  assignedToId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TicketStatus {
  OPEN
  RESOLVED
  CLOSED
}

enum Category {
  GENERAL_QUESTION
  TECHNICAL_QUESTION
  REFUND_REQUEST
}
